rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Products rules - Seeding/updates are allowed by the client app
    match /products/{productId} {
      allow read, write: if true;
    }

    // Showroom custom products rules
    match /showroom_custom_products/{productId} {
      allow read, write: if true;
    }

    // Feedback rules - Seeding/submitting feedback
    match /feedback/{feedbackId} {
      allow read, write: if true;
    }

    // GM Queries rules - Seeding/manager enquiries
    match /gm_queries/{queryId} {
      allow read, write: if true;
    }

    // Settings rules - Seeding/updates of campaign, bank, managers, socials, gallery, videoList
    match /settings/{settingId} {
      allow read, write: if true;
    }

    // Receipts rules - Seeding/registration and retrieval of official clearance slips
    match /receipts/{receiptId} {
      allow read, write: if true;
    }
  }
}
